# alteration-app config template — copy to .env and fill in.

# HTTP server port (Vite proxies /api to this).
PORT=8080

# SQL Server connection — QuickBill's tenant DB. Adjust user/password/host/
# port/database to match your install. Find the port via
# `Get-NetTCPConnection -OwningProcess (Get-Process sqlservr).Id`.
DATABASE_URL=sqlserver://sa:MyPassword@192.168.68.105:64070?database=QbAppDb1
