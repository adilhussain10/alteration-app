# alteration-app config template — copy to .env and fill in.

# HTTP server port (Vite proxies /api to this).
PORT=8080

# Postgres DSN — the app's single source of truth.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
#
# Examples:
#   Local docker:   postgres://postgres:postgres@localhost:5432/alteration?sslmode=disable
#   Railway:        postgres://postgres:PASS@containers-us-west-NN.railway.app:6543/railway
#   Supabase:       postgres://postgres:PASS@db.PROJECT.supabase.co:5432/postgres
#   Neon:           postgres://USER:PASS@ep-XXX.us-east-2.aws.neon.tech/dbname?sslmode=require
#
# After setting this, apply the schema once:
#   psql "$DATABASE_URL" -f db/migrations/001_init_postgres.sql
DATABASE_URL=postgres://USER:123456@HOST:5432/DBNAME?sslmode=require

# SQL Server DSN — source for the sync-from-sqlserver binary.
# Only needed by cmd/sync-from-sqlserver, not by cmd/server.
# Format: sqlserver://USER:PASSWORD@HOST:PORT?database=NAME
SQLSERVER_URL=sqlserver://sa:Success24@localhost:64070?database=qbsysdb
